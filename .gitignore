# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# kubeconfig / cluster credentials
.kubectl/

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# LinkedIn Playwright session (secrets)
.linkedin_state.json
data/linkedin_state.json
.secrets/

# local job apply artifacts (screenshots, generated CVs)
data/job-logs/
data/unlockcareer/applications/

# local sqlite
cv.db
*.db-journal
*.db

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
